rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    // ── 슈퍼어드민: 이메일 토큰으로만 판단 (Firestore 문서 조작 불가) ──
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email == 'ty71028711@gmail.com';
    }

    // ── 승인된 사용자 여부 ──
    function isApproved() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    // ────────────────────────────────────────────────────────────
    // users 컬렉션
    // ────────────────────────────────────────────────────────────
    match /users/{uid} {

      // 본인 또는 관리자만 읽기
      allow read: if request.auth != null &&
                     (request.auth.uid == uid || isAdmin());

      // 최초 가입: pending 상태로만 생성, uid·email 위조 불가
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.status    == 'pending'
                    && request.resource.data.uid       == request.auth.uid
                    && request.resource.data.email     == request.auth.token.email;

      // 업데이트:
      //   - 관리자: 모든 필드 수정 가능
      //   - 본인:   status / approvedAt / planStatus / expiryDate 변경 불가
      allow update: if request.auth != null && (
        isAdmin() ||
        (
          request.auth.uid == uid &&
          !request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasAny(['status', 'approvedAt', 'planStatus', 'expiryDate'])
        )
      );

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // visits 컬렉션 (매물 데이터): 승인된 본인만
    // ────────────────────────────────────────────────────────────
    match /visits/{uid}/items/{docId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid
                         && isApproved();
    }

    // ────────────────────────────────────────────────────────────
    // archives 컬렉션 (보관함): 승인된 본인만
    // ────────────────────────────────────────────────────────────
    match /archives/{uid}/saves/{docId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid
                         && isApproved();
    }

    // ────────────────────────────────────────────────────────────
    // settings 컬렉션 (명함 설정): 승인된 본인만
    // ────────────────────────────────────────────────────────────
    match /settings/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid
                         && isApproved();
    }

    // ────────────────────────────────────────────────────────────
    // applications 컬렉션 (서비스 신청서)
    //   - 로그인한 사용자: 생성만 가능
    //   - 관리자: 읽기·수정·삭제 가능
    // ────────────────────────────────────────────────────────────
    match /applications/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // 그 외 모든 경로 차단
    // ────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

  }

}
