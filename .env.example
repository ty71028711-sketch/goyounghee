# ── 카카오 지도 ──────────────────────────────────────────
# Kakao Developers > 내 애플리케이션 > 앱 키 > JavaScript 키
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=

# ── 관리자 이메일 ─────────────────────────────────────────
# 쉼표로 구분 (예: admin@example.com,admin2@example.com)
NEXT_PUBLIC_ADMIN_EMAILS=
NEXT_PUBLIC_ADMIN_EMAIL=

# ── Firebase (lib/firebase.ts 에 하드코딩 — 참고용) ───────
# 아래 값들은 현재 lib/firebase.ts에 직접 작성되어 있습니다.
# env로 분리하려면 lib/firebase.ts 수정이 필요합니다.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Vercel (자동 생성 — 직접 입력 불필요) ─────────────────
# VERCEL_OIDC_TOKEN=   ← Vercel CLI가 자동 주입
# APP_SECRET=          ← Vercel CLI가 자동 주입
